    },
    {
      "id": "phrases/deep-breath-in",
      "text": "Deep breath in",
      "style": "pranayama",
      "start": 49.52,
      "end": 51.44,
      "duration": 1.92
    },
    {
      "id": "phrases/observe-energy",
      "text": "Palms in your knees. Observe the flow of energy.",
      "style": "pranayama",
      "start": 51.84,
      "end": 55.28,
      "duration": 3.44
    },
    {
      "id": "phrases/slowly-drop-leg",
      "text": "Slowly drop the leg down.",
      "style": "physio",
      "start": 55.68,
      "end": 58.24,
      "duration": 2.56
    },
    {
      "id": "phrases/lower-the-leg",
      "text": "Lower the leg.",
      "style": "physio",
      "start": 58.64,
      "end": 59.92,
      "duration": 1.28
    },
    {
      "id": "cues/knee-lock",
      "text": "Lock the knee. Bend the foot up. Do not lift the leg.",
      "style": "physio",
      "start": 60.32,
      "end": 64.56,
      "duration": 4.24
    },
    {
      "id": "cues/leg-raise-up",
      "text": "Raise the leg about ten inches up. Keep the knee locked. Bend the foot up. Do not let the leg oscillate.",
      "style": "physio",
      "start": 64.96,
      "end": 73.28,
      "duration": 8.32
    },
    {
      "id": "cues/leg-raise-side",
      "text": "Turn the leg sideways at the same height. Hold the knee tight. Foot stays bent up.",
      "style": "physio",
      "start": 73.68,
      "end": 80.16,
      "duration": 6.48
    },
    {
      "id": "cues/shoulder-strap",
      "text": "Pull the strap down with both hands. Spine erect, shoulders relaxed. Breathe normally.",
      "style": "physio",
      "start": 80.56,
      "end": 87.36,
      "duration": 6.8
    },
    {
      "id": "cues/knee-to-chest",
      "text": "Pull both knees tightly to your chest. Hands clasped over shins. Keep your head and shoulders relaxed.",
      "style": "physio",
      "start": 87.76,
      "end": 95.04,
      "duration": 7.28
    },
    {
      "id": "cues/cat-pose",
      "text": "Arch your back up toward the ceiling. Tuck your head down. Engage your core.",
      "style": "physio",
      "start": 95.44,
      "end": 100.88,
      "duration": 5.44
    },
    {
      "id": "setup/pranayama-stage-1",
      "text": "Sit in Vajrasana with spine erect. Place your thumbs on your hipbone, hands parallel to the ground at the navel line. Take a normal breath in, and let go. Take a deep breath in, and let go. When you are ready, the timer will begin.",
      "style": "pranayama",
      "start": 101.28,
      "end": 117.68,
      "duration": 16.4
    },
    {
      "id": "setup/pranayama-stage-2",
      "text": "Tuck your thumbs deep into your armpits with hands parallel to the ground. Relax your shoulders, gentle smile, spine erect. Take a normal breath in, and let go. Take a deep breath in, and let go. When you are ready, the timer will begin.",
      "style": "pranayama",
      "start": 118.08,
      "end": 135.2,
      "duration": 17.12
    },
    {
      "id": "setup/pranayama-stage-3",
      "text": "Point your elbows toward the ceiling, biceps touching your ears. Place your palms on your shoulder blade, not overlapping. Spine erect. Take a deep breath in, and let go. Take another deep breath in, and let go. When you are ready, the timer will begin.",
      "style": "pranayama",
      "start": 135.6,
      "end": 154.0,
      "duration": 18.4
    },
    {
      "id": "setup/bhastrika-round",
      "text": "Palms in loose fists next to your shoulders. Spine erect, chin up, elbows close to the body. Relax your shoulders. Take a normal breath in, and let go. Take a deep breath in, and exhale fully. When you are ready, forceful breath begins.",
      "style": "pranayama",
      "start": 154.4,
      "end": 172.0,
      "duration": 17.6
    },
    {
      "id": "setup/om-chant",
      "text": "Slowly come out of Vajrasana and sit comfortably with spine erect. Eyes gently closed. When you are ready, the Om chants will begin.",
      "style": "pranayama",
      "start": 172.4,
      "end": 182.16,
      "duration": 9.76
    },
    {
      "id": "setup/shoulder-strap-stretch",
      "text": "Stand straight against a wall. Loop the fabric strap around the front of your shoulders so it crosses behind your back. Clasp both hands behind your back on the strap ends. When you are ready, the timer will begin.",
      "style": "physio",
      "start": 182.56,
      "end": 196.48,
      "duration": 13.92
    },
    {
      "id": "setup/knee-to-chest-stretch",
      "text": "Lie flat on your back on a mat or padded surface. Bring both knees up and clasp your hands over your shins. When you are ready, the timer will begin.",
      "style": "physio",
      "start": 196.88,
      "end": 208.08,
      "duration": 11.2
    },
    {
      "id": "setup/cat-pose",
      "text": "Position yourself on hands and knees on a mat. Hands under shoulders, knees under hips. When you are ready, the timer will begin.",
      "style": "physio",
      "start": 208.48,
      "end": 218.56,
      "duration": 10.08
    },
    {
      "id": "setup/knee-lock",
      "text": "Sit in a chair where your thigh is fully supported. A bigger chair is better. Sit very straight. Lift the leg up just until it is straight. Do not lift the leg higher. Bend the foot up. Lock the knee. When you are ready, the timer will begin.",
      "style": "physio",
      "start": 218.96,
      "end": 238.08,
      "duration": 19.12
    },
    {
      "id": "setup/leg-raise-hold",
      "text": "Lie flat on your back, or sit supported as your therapist instructed. You will do two movements per leg: leg up, then leg sideways. Keep the knee locked and the foot bent throughout. When you are ready, the timer will begin.",
      "style": "physio",
      "start": 238.48,
      "end": 255.76,
      "duration": 17.28
    },
    {
      "id": "setup/leg-raise-transition",
      "text": "Now the second movement. Same leg, sideways at the same height. When you are ready, the timer will continue.",
      "style": "physio",
      "start": 256.16,
      "end": 265.36,
      "duration": 9.2
    },
